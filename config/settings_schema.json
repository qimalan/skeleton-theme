[
  {
    "name": "Theme info",
    "theme_name": "Skeleton Framework",
    "theme_version": "1.0.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://shopify.dev/docs/storefronts/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "assistant_n4",
        "label": "Base font"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Page width",
        "options": [
          { "value": "90rem", "label": "Narrow" },
          { "value": "110rem", "label": "Wide" },
          { "value": "120rem", "label": "Extra wide" }
        ],
        "default": "110rem"
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 12,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "Page margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_background", "default": "#ffffff", "label": "Background" },
      { "type": "color", "id": "color_foreground", "default": "#111111", "label": "Foreground" },
      { "type": "color", "id": "color_accent", "default": "#111111", "label": "Accent" },
      { "type": "color", "id": "color_surface", "default": "#f6f6f4", "label": "Surface" },
      { "type": "color", "id": "color_border", "default": "#e5e5e0", "label": "Border" },
      { "type": "color", "id": "color_muted", "default": "#666666", "label": "Muted text" }
    ]
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 100
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Radius",
    "settings": [
      {
        "type": "range",
        "id": "button_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Button radius",
        "default": 10
      },
      {
        "type": "range",
        "id": "input_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Input radius",
        "default": 10
      },
      {
        "type": "range",
        "id": "card_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Card radius",
        "default": 14
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      { "type": "checkbox", "id": "sticky_header", "label": "Sticky header", "default": true },
      { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
      { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
      { "type": "checkbox", "id": "show_cart_count", "label": "Show cart count", "default": true }
    ]
  },
  {
    "name": "Cards",
    "settings": [
      {
        "type": "select",
        "id": "card_style",
        "label": "Card style",
        "options": [
          { "value": "plain", "label": "Plain" },
          { "value": "surface", "label": "Surface" }
        ],
        "default": "surface"
      },
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Card image ratio",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "portrait", "label": "Portrait" },
          { "value": "landscape", "label": "Landscape" }
        ],
        "default": "square"
      },
      { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
      { "type": "checkbox", "id": "show_secondary_image", "label": "Show secondary image", "default": false }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },
      { "type": "checkbox", "id": "currency_code_enabled", "label": "Show currency code", "default": false },
      {
        "type": "text",
        "id": "footer_note",
        "label": "Footer note",
        "default": "A lean starting point for solo Shopify builds."
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "url",
        "id": "social_twitter_link",
        "label": "X / Twitter"
      },
      {
        "type": "url",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_instagram_link",
        "label": "Instagram"
      }
    ]
  }
]
