<section class="page-width contact-section">
  <div class="section-heading">
    <p class="section-heading__eyebrow">{{ 'contact.title' | t }}</p>
    <h2>{{ section.settings.heading | escape }}</h2>
  </div>

  {% render 'contact-form', section_id: section.id %}
</section>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Get in touch",
      "label": "Heading"
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
