{%- liquid
  assign featured_product = section.settings.product
  assign current_variant = featured_product.selected_or_first_available_variant
-%}

<section class="page-width featured-product-section" data-product-root>
  {%- if featured_product != blank -%}
    <div class="featured-product-section__grid featured-product-section__grid--{{ section.settings.media_position }}">
      <div class="featured-product-section__media">
        {%- if featured_product.featured_media != blank -%}
          {% render 'product-media', media: featured_product.featured_media, loading: 'lazy' %}
        {%- endif -%}
      </div>

      <div class="featured-product-section__content">
        <div class="section-heading">
          <p class="section-heading__eyebrow">{{ featured_product.vendor }}</p>
          <h2>{{ featured_product.title }}</h2>
        </div>

        <div data-variant-price>
          {% render 'price', product: featured_product, variant: current_variant, show_compare_at_price: true %}
        </div>

        {%- if featured_product.description != blank -%}
          <div class="rte">{{ featured_product.description }}</div>
        {%- endif -%}

        {%- form 'product', featured_product, class: 'product-form', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {% render 'variant-picker', product: featured_product, id_prefix: section.id %}

          <label class="field product-form__quantity">
            <span>{{ 'products.product.quantity.label' | t }}</span>
            <input class="field__input" type="number" name="quantity" value="1" min="1">
          </label>

          <div class="featured-product-section__purchase">
            <button
              class="button"
              type="submit"
              name="add"
              data-add-text="{{ 'products.product.add_to_cart' | t }}"
              data-sold-out-text="{{ 'products.product.sold_out' | t }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
            <div
              data-variant-status
              data-available-text=""
              data-unavailable-text="{{ 'products.product.sold_out' | t }}"
              aria-live="polite"
            ></div>
          </div>
        {%- endform -%}
      </div>
    </div>
  {%- else -%}
    <div class="section-heading">
      <p class="section-heading__eyebrow">{{ 'featured_product.eyebrow' | t }}</p>
      <h2>{{ 'featured_product.title' | t }}</h2>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .featured-product-section__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .featured-product-section__grid--text_first .featured-product-section__media {
    order: 2;
  }

  .featured-product-section__content {
    display: grid;
    gap: 1rem;
  }

  .featured-product-section__media .product-media,
  .featured-product-section__media .image,
  .featured-product-section__media .image__element,
  .featured-product-section__media .product-media__element {
    width: 100%;
  }

  .featured-product-section__media .product-media__element {
    aspect-ratio: 1;
    height: auto;
  }

  .featured-product-section .product-form {
    display: grid;
    gap: 1rem;
  }

  .featured-product-section__purchase {
    display: grid;
    gap: 0.75rem;
  }

  .featured-product-section .product-form__quantity {
    max-width: 8rem;
  }

  @media (max-width: 749px) {
    .featured-product-section__grid {
      grid-template-columns: 1fr;
    }

    .featured-product-section__grid--text_first .featured-product-section__media {
      order: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "text_first", "label": "Text first" }
      ],
      "default": "image_first",
      "label": "Media position"
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
