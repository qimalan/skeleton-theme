{%- if section.blocks.size > 0 -%}
  <section
    class="announcement-bar"
    style="
      --announcement-background: {{ section.settings.background }};
      --announcement-foreground: {{ section.settings.foreground }};
    "
  >
    <div class="announcement-bar__inner page-width announcement-bar__inner--{{ section.settings.alignment }}">
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          {%- if block.settings.link != blank -%}
            <a class="announcement-bar__item" href="{{ block.settings.link | escape }}" {{ block.shopify_attributes }}>
          {%- else -%}
            <p class="announcement-bar__item" {{ block.shopify_attributes }}>
          {%- endif -%}
            {%- if block.settings.icon != 'none' -%}
              {% render 'icon', icon: block.settings.icon %}
            {%- endif -%}
            <span>{{ block.settings.text }}</span>
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </p>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background: var(--announcement-background);
    color: var(--announcement-foreground);
    font-size: 0.9rem;
  }

  .announcement-bar__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
    min-height: 2.75rem;
    padding-block: 0.5rem;
  }

  .announcement-bar__inner--left {
    justify-content: flex-start;
  }

  .announcement-bar__inner--center {
    justify-content: center;
  }

  .announcement-bar__inner--right {
    justify-content: flex-end;
  }

  .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: inherit;
    text-decoration: none;
  }

  .announcement-bar__item[href]:hover {
    text-decoration: underline;
  }

  @media (max-width: 749px) {
    .announcement-bar__inner {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .announcement-bar__inner::-webkit-scrollbar {
      display: none;
    }

    .announcement-bar__item {
      flex: 0 0 auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "default": "#111111",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "foreground",
      "default": "#ffffff",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Alignment"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "gift", "label": "Gift" },
            { "value": "star", "label": "Star" }
          ],
          "default": "none",
          "label": "Icon"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Free shipping on orders over $75",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
