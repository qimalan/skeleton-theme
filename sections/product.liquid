{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="page-width product-page" data-product-root>
  <div class="product-page__grid">
    <div class="product-page__media">
      {%- if product.media != blank -%}
        <div class="product-page__gallery">
          {%- for media in product.media limit: 6 -%}
            {%- liquid
              assign media_loading = 'lazy'
              if forloop.first
                assign media_loading = 'eager'
              endif
            -%}
            {% render 'product-media', media: media, loading: media_loading %}
          {%- endfor -%}
        </div>
      {%- else -%}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'product-page__placeholder' }}
      {%- endif -%}
    </div>

    <div class="product-page__content">
      <div class="section-heading">
        <p class="section-heading__eyebrow">{{ product.vendor }}</p>
        <h1>{{ product.title }}</h1>
      </div>

      <div data-variant-price>
        {% render 'price', product: product, variant: current_variant, show_compare_at_price: true %}
      </div>

      {%- if product.description != blank -%}
        <div class="rte">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product, class: 'product-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {% render 'variant-picker', product: product, id_prefix: section.id %}

        <label class="field product-form__quantity">
          <span>{{ 'products.product.quantity.label' | t }}</span>
          <input class="field__input" type="number" name="quantity" value="1" min="1">
        </label>

        <div class="product-page__purchase">
          <button
            class="button"
            type="submit"
            name="add"
            data-add-text="{{ 'products.product.add_to_cart' | t }}"
            data-sold-out-text="{{ 'products.product.sold_out' | t }}"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
          <div
            data-variant-status
            data-available-text=""
            data-unavailable-text="{{ 'products.product.sold_out' | t }}"
            aria-live="polite"
          ></div>
        </div>
      {%- endform -%}

      {%- if product.metafields.custom.specs != blank -%}
        <div class="rte">{{ product.metafields.custom.specs | metafield_tag }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-page__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 2rem;
    align-items: start;
  }

  .product-page__gallery {
    display: grid;
    gap: 1rem;
  }

  .product-media,
  .product-media .image,
  .product-media .image__element,
  .product-media__element {
    width: 100%;
  }

  .product-media__element {
    aspect-ratio: 1;
    height: auto;
  }

  .product-page__placeholder {
    width: 100%;
    height: auto;
  }

  .product-form {
    display: grid;
    gap: 1rem;
  }

  .product-page__purchase {
    display: grid;
    gap: 0.75rem;
  }

  .product-form__quantity {
    max-width: 8rem;
  }

  @media (max-width: 749px) {
    .product-page__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
