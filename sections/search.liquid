<section class="page-width">
  <div class="section-heading">
    <p class="section-heading__eyebrow">{{ 'search.title' | t }}</p>
    <h1>{{ 'search.title' | t }}</h1>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <input type="hidden" name="options[prefix]" value="last">
    <div class="field">
      <input
        class="field__input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
      >
    </div>
    <button class="button" type="submit">{{ 'search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
    {%- else -%}
      <p>{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

      <div class="cards-grid product-grid">
        {%- paginate search.results by 24 -%}
          {%- for result in search.results -%}
            {%- if result.object_type == 'product' -%}
              {% render 'card-product', card_product: result %}
            {%- else -%}
              <article class="card card--surface">
                <div class="card__body">
                  <h3 class="card__title"><a href="{{ result.url }}">{{ result.title | escape }}</a></h3>
                  {%- if result.object_type == 'article' and result.image != blank -%}
                    {% render 'image', image: result.image, url: result.url, width: 1200, height: 800, crop: 'center' %}
                  {%- endif -%}
                </div>
              </article>
            {%- endif -%}
          {%- endfor -%}

          {% render 'pagination', paginate: paginate %}
        {%- endpaginate -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
