<footer class="site-footer">
  <div class="site-footer__inner page-width">
    <div class="site-footer__brand">
      <strong>{{ shop.name }}</strong>
      {%- if settings.footer_note != blank -%}
        <p>{{ settings.footer_note }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.menu != blank -%}
      <nav class="site-footer__nav" aria-label="{{ 'general.navigation' | t }}">
        <ul role="list">
          {%- for link in section.settings.menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="site-footer__meta">
      {%- if settings.show_payment_icons -%}
        <div class="site-footer__payments">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- render 'social-icons' -%}

      {%- if settings.show_footer_localization -%}
        {% render 'localization-form', id_prefix: 'FooterLocalization' %}
      {%- endif -%}

      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</small>
    </div>
  </div>

  {%- if section.settings.show_policy_links -%}
    <div class="site-footer__policies page-width">
      {%- for policy in shop.policies -%}
        {%- if policy != blank -%}
          <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</footer>

{% stylesheet %}
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 1.5rem;
    padding-block: 2rem;
  }

  .site-footer__brand,
  .site-footer__nav,
  .site-footer__meta {
    display: grid;
    gap: 0.75rem;
  }

  .site-footer__nav ul {
    display: grid;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-footer__payments {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .site-footer__payments svg {
    width: 2.5rem;
    height: 1.6rem;
  }

  .site-footer .localization-form {
    display: grid;
    gap: 0.6rem;
  }

  .site-footer__policies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    padding-block: 0 1.5rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 749px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
    }

    .site-footer__policies {
      display: grid;
      gap: 0.6rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "default": true,
      "label": "Show policy links"
    }
  ]
}
{% endschema %}
