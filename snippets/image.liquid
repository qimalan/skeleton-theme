{% doc %}
Renders a responsive image, optionally wrapped in a link.
@param {image} image - Image object.
@param {string} [url] - Optional link URL.
@param {string} [class] - Optional wrapper class.
@param {number} [width] - Output width.
@param {number} [height] - Output height.
@param {string} [crop] - Crop position.
@param {string} [loading] - Loading strategy.
{% enddoc %}

{%- liquid
  assign output_width = width | default: image.width
  assign output_height = height | default: image.height
  assign loading_strategy = loading | default: 'lazy'
  assign wrapper = 'div'

  if url != blank
    assign wrapper = 'a'
  endif
-%}

{% if image != blank %}
  <{{ wrapper }} class="image{% if class != blank %} {{ class | escape }}{% endif %}" {% if url != blank %}href="{{ url | escape }}"{% endif %}>
    {{ image
      | image_url: width: output_width, height: output_height, crop: crop
      | image_tag: class: 'image__element', loading: loading_strategy, alt: image.alt
    }}
  </{{ wrapper }}>
{% endif %}
