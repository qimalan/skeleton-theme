{% doc %}
Renders the theme contact form.
{% enddoc %}

{% form 'contact', id: 'ContactForm-' | append: section_id, class: 'contact-section__form' %}
  {%- if form.posted_successfully? -%}
    <p class="contact-section__message" role="status">{{ 'contact.success' | t }}</p>
  {%- endif -%}

  {{ form.errors | default_errors }}

  <div class="contact-section__grid">
    <label class="field">
      <span>{{ 'contact.name' | t }}</span>
      <input class="field__input" type="text" name="contact[name]" autocomplete="name" value="{{ form.name | escape }}">
    </label>
    <label class="field">
      <span>{{ 'contact.email' | t }}</span>
      <input class="field__input" type="email" name="contact[email]" autocomplete="email" value="{{ form.email | escape }}" required>
    </label>
    <label class="field">
      <span>{{ 'contact.phone' | t }}</span>
      <input class="field__input" type="tel" name="contact[phone]" autocomplete="tel" value="{{ form.phone | escape }}">
    </label>
    <label class="field contact-section__full">
      <span>{{ 'contact.message' | t }}</span>
      <textarea class="field__input" name="contact[body]" rows="8" required>{{ form.body | escape }}</textarea>
    </label>
  </div>

  <button class="button" type="submit">{{ 'contact.submit' | t }}</button>
{% endform %}

{% stylesheet %}
  .contact-section__form {
    display: grid;
    gap: 1rem;
  }

  .contact-section__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-section__full {
    grid-column: 1 / -1;
  }

  .contact-section__message {
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 749px) {
    .contact-section__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}
