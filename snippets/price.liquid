{% doc %}
Renders a product or variant price.
@param {product} [product] - Product object.
@param {variant} [variant] - Variant object.
@param {string} [class] - Extra classes.
@param {boolean} [show_compare_at_price] - Show compare-at price.
{% enddoc %}

{%- liquid
  assign target = variant | default: product.selected_or_first_available_variant | default: product
  assign compare_at_price = target.compare_at_price | default: 0
  assign price = target.price | default: 0
  assign money_price = price | money
  assign money_compare = compare_at_price | money

  if settings.currency_code_enabled
    assign money_price = price | money_with_currency
    assign money_compare = compare_at_price | money_with_currency
  endif
-%}

{%- if target != blank -%}
  <div class="price {{ class }}{% if compare_at_price > price %} price--sale{% endif %}{% unless target.available %} price--sold-out{% endunless %}">
    <span class="price__current">
      {%- if product != blank and product.price_varies and variant == blank and target == product -%}
        {{ 'products.price.from_price_html' | t: price: money_price }}
      {%- else -%}
        {{ money_price }}
      {%- endif -%}
    </span>

    {%- if show_compare_at_price and compare_at_price > price -%}
      <s class="price__compare">{{ money_compare }}</s>
    {%- endif -%}
  </div>
{%- endif -%}
