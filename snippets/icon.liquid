{% doc %}
Renders a small inline SVG icon.
@param {string} [icon] - Icon name.
{% enddoc %}

{%- liquid
  assign icon_name = icon | default: 'arrow-right'
-%}

<svg class="icon icon--{{ icon_name }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
  {%- case icon_name -%}
    {%- when 'menu' -%}
      <path d="M4 7h16M4 12h16M4 17h16"></path>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="5.5"></circle>
      <path d="m15.5 15.5 4 4"></path>
    {%- when 'account' -%}
      <path d="M12 13a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"></path>
      <path d="M5 20a7 7 0 0 1 14 0"></path>
    {%- when 'cart' -%}
      <path d="M6 7h15l-2 8H8L6 7Z"></path>
      <path d="M6 7 5 4H2"></path>
      <circle cx="10" cy="19" r="1"></circle>
      <circle cx="17" cy="19" r="1"></circle>
    {%- when 'close' -%}
      <path d="m6 6 12 12M18 6 6 18"></path>
    {%- when 'chevron-down' -%}
      <path d="m6 9 6 6 6-6"></path>
    {%- when 'chevron-left' -%}
      <path d="m14 6-6 6 6 6"></path>
    {%- when 'chevron-right' -%}
      <path d="m10 6 6 6-6 6"></path>
    {%- when 'arrow-left' -%}
      <path d="M11 6 5 12l6 6"></path>
      <path d="M19 12H5"></path>
    {%- when 'arrow-right' -%}
      <path d="M13 6l6 6-6 6"></path>
      <path d="M5 12h14"></path>
    {%- when 'plus' -%}
      <path d="M12 5v14M5 12h14"></path>
    {%- when 'minus' -%}
      <path d="M5 12h14"></path>
    {%- when 'check' -%}
      <path d="m5 12 5 5 9-10"></path>
    {%- else -%}
      <path d="M13 5 6 12l7 7"></path>
      <path d="M6 12h12"></path>
  {%- endcase -%}
</svg>
