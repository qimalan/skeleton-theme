{% doc %}
Renders a small inline SVG icon.
@param {string} [icon] - Icon name.
{% enddoc %}

{%- liquid
  assign icon_name = icon | default: 'arrow-right'
-%}

<svg class="icon icon--{{ icon_name }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
  {%- case icon_name -%}
    {%- when 'menu' -%}
      <path d="M4 7h16M4 12h16M4 17h16"></path>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="5.5"></circle>
      <path d="m15.5 15.5 4 4"></path>
    {%- when 'account' -%}
      <path d="M12 13a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"></path>
      <path d="M5 20a7 7 0 0 1 14 0"></path>
    {%- when 'cart' -%}
      <path d="M6 7h15l-2 8H8L6 7Z"></path>
      <path d="M6 7 5 4H2"></path>
      <circle cx="10" cy="19" r="1"></circle>
      <circle cx="17" cy="19" r="1"></circle>
    {%- when 'close' -%}
      <path d="m6 6 12 12M18 6 6 18"></path>
    {%- when 'chevron-down' -%}
      <path d="m6 9 6 6 6-6"></path>
    {%- when 'chevron-left' -%}
      <path d="m14 6-6 6 6 6"></path>
    {%- when 'chevron-right' -%}
      <path d="m10 6 6 6-6 6"></path>
    {%- when 'arrow-left' -%}
      <path d="M11 6 5 12l6 6"></path>
      <path d="M19 12H5"></path>
    {%- when 'arrow-right' -%}
      <path d="M13 6l6 6-6 6"></path>
      <path d="M5 12h14"></path>
    {%- when 'plus' -%}
      <path d="M12 5v14M5 12h14"></path>
    {%- when 'minus' -%}
      <path d="M5 12h14"></path>
    {%- when 'check' -%}
      <path d="m5 12 5 5 9-10"></path>
    {%- when 'truck' -%}
      <path d="M3 7h11v9H3z"></path>
      <path d="M14 10h4l3 3v3h-7z"></path>
      <circle cx="7" cy="18" r="2"></circle>
      <circle cx="17" cy="18" r="2"></circle>
    {%- when 'shield' -%}
      <path d="M12 3 5 6v5c0 4.5 2.9 8.4 7 10 4.1-1.6 7-5.5 7-10V6l-7-3Z"></path>
      <path d="m9 12 2 2 4-5"></path>
    {%- when 'return' -%}
      <path d="M9 7 4 12l5 5"></path>
      <path d="M5 12h10a5 5 0 1 1 0 10h-2"></path>
    {%- when 'chat' -%}
      <path d="M4 5h16v11H8l-4 4V5Z"></path>
      <path d="M8 9h8M8 13h5"></path>
    {%- when 'gift' -%}
      <path d="M4 10h16v10H4z"></path>
      <path d="M12 10v10M4 14h16M7.5 7.5C7.5 6.1 8.6 5 10 5c2 0 2 5 2 5S7.5 10 7.5 7.5ZM16.5 7.5C16.5 6.1 15.4 5 14 5c-2 0-2 5-2 5s4.5 0 4.5-2.5Z"></path>
    {%- when 'star' -%}
      <path d="m12 3 2.8 5.7 6.2.9-4.5 4.4 1.1 6.2L12 17.3 6.4 20.2 7.5 14 3 9.6l6.2-.9L12 3Z"></path>
    {%- when 'sparkle' -%}
      <path d="M12 3l1.5 5.5L19 10l-5.5 1.5L12 17l-1.5-5.5L5 10l5.5-1.5L12 3Z"></path>
      <path d="M19 16l.7 2.3L22 19l-2.3.7L19 22l-.7-2.3L16 19l2.3-.7L19 16Z"></path>
    {%- else -%}
      <path d="M13 5 6 12l7 7"></path>
      <path d="M6 12h12"></path>
  {%- endcase -%}
</svg>
